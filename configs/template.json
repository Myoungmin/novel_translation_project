{
  "work_id": "sample-work",
  "source_file": "sources/sample_novel.txt",
  "output_dir": "artifacts/sample-work",
  "encodings": ["utf-8", "utf-8-sig", "cp949"],
  "clean_exclude_types": ["afterword"],
  "html_output": {
    "enabled": true,
    "split_size": 300000,
    "_comment": "split_size 설정: 숫자(글자수) 또는 프리셋('light', 'medium', 'heavy')",
    "_presets": "light=15000 / medium=30000 / heavy=50000"
  },
  "patterns": [
    {
      "name": "afterword",
      "kind": "afterword",
      "regex": "작품 후기",
      "title_source": "literal",
      "title_literal": "작품 후기"
    },
    {
      "name": "five_digit_chapter",
      "kind": "chapter",
      "regex": "^\\d{5}\\s+.*={20,}$",
      "title_source": "match",
      "title_regex": "^(?P<number>\\d{5})\\s+(?P<title>.*?)\\s+=+$"
    }
  ]
}
