{
  "work_id": "sample-work",
  "run_name": "gemini-3.1-flash-lite-preview",
  "preprocess_config": "configs/template.json",
  "glossary_file": "glossaries/template.json",
  "output_dir": "artifacts/sample-work/runs",
  "model": {
    "provider": "gemini-generate-content",
    "model": "gemini-3.1-flash-lite-preview",
    "base_url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite-preview:generateContent",
    "api_key_env": "GEMINI_API_KEY",
    "gemini_auth_mode": "query",
    "temperature": 0.2,
    "max_output_tokens": 4000,
    "timeout_seconds": 120,
    "retry": {
      "max_attempts": 2,
      "initial_delay_seconds": 2,
      "backoff_multiplier": 2.0,
      "max_delay_seconds": 8,
      "total_timeout_seconds": 90
    }
  },
  "translation": {
    "source_language": "Korean",
    "target_language": "English",
    "max_chars_per_chunk": 4500
  },
  "selection": {
    "kinds": ["chapter"],
    "limit": 1000
  }
}
